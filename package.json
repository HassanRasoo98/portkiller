{
  "name": "portkiller",
  "version": "1.0.0",
  "description": "Cross-platform desktop app to detect common ports and free them by killing occupying processes",
  "main": "dist-electron/electron/main.js",
  "author": "Hassan Rasool",
  "license": "MIT",
  "homepage": "https://github.com/HassanRasoo98/portkiller",
  "repository": {
    "type": "git",
    "url": "https://github.com/HassanRasoo98/portkiller.git"
  },
  "keywords": [
    "ports",
    "kill-port",
    "developer-tools",
    "electron",
    "cross-platform",
    "open-source"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.node.json && vite build && tsc -p tsconfig.electron.json",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"vite\" \"wait-on http://127.0.0.1:5173 && tsc -p tsconfig.electron.json && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "electron:build": "npm run build && electron-builder",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "build": {
    "appId": "com.portkiller.app",
    "productName": "PortKiller",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development"
    }
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.5",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4.5.0",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^35.2.1",
    "electron-builder": "^26.0.12",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.1.4",
    "wait-on": "^8.0.3"
  }
}
